# The Reclaim Scheduling Link ID — the `data-id` attribute from the embed snippet.
# In Reclaim: Scheduling Links → the link's ⋮ menu → Share → Embed → copy the UUID
# from `data-id`. When unset, /book renders an "email aaron@hellosavvy.design"
# fallback instead of the booking widget.
NEXT_PUBLIC_RECLAIM_LINK_ID=

# Shared secret for verifying inbound webhooks from Reclaim.
# Set the same value in Reclaim's webhook config when registering
# https://hellosavvy.design/api/reclaim/webhook as the endpoint.
RECLAIM_WEBHOOK_SECRET=

# Stripe — used by the home page Blueprint CTA.
# Test keys (sk_test_...) for local + preview. Live keys (sk_live_...) only in
# production. Never commit either. From Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=

# Webhook signing secret. For local dev, run:
#   stripe listen --forward-to localhost:3000/api/webhooks/stripe
# and paste the printed whsec_... value here. For production, copy from
# Stripe Dashboard → Developers → Webhooks → your endpoint.
STRIPE_WEBHOOK_SECRET=

# Optional — set to the Price ID (price_...) from the Blueprint product in
# Stripe Dashboard. When unset, checkout.ts falls back to inline price_data
# so the flow still works locally without round-tripping through Dashboard.
STRIPE_BLUEPRINT_PRICE_ID=

# G2M monthly subscription Price ID. REQUIRED for startG2MCheckout (no
# fallback — Stripe requires a real Price for recurring billing).
STRIPE_G2M_PRICE_ID=

# G2M annual prepay Price ID (optional — $10k/yr per §2 of the setup doc).
STRIPE_G2M_ANNUAL_PRICE_ID=

# Base URL used to build Stripe success/cancel redirect URLs.
# Local: http://localhost:3000. Production: https://hellosavvy.design.
NEXT_PUBLIC_APP_URL=http://localhost:3000
